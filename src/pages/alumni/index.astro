---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";

const allAlumni = await getCollection("alumni");
const sortedAlumni = allAlumni.sort(
    (a, b) => a.data.graduationYear - b.data.graduationYear,
);

const graduationYears = [
    ...new Set(allAlumni.map((a) => a.data.graduationYear)),
].sort((a, b) => b - a);
const locations = [
    ...new Set(allAlumni.map((a) => a.data.location).filter(Boolean)),
].sort();
---

<Layout
    title="Alumni Directory"
    description="Connect with fellow Wayfarers Hiking Society alumni"
>
    <section class="py-16 bg-white">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <h1 class="text-4xl font-bold text-center mb-4">
                Alumni Directory
            </h1>
            <p class="text-xl text-gray-600 text-center mb-12">
                Connect with {allAlumni.length} fellow Wayfarers alumni
            </p>

            <!-- Search and Filter -->
            <div class="mb-8 bg-gray-50 p-6 rounded-lg">
                <form
                    id="filter-form"
                    class="grid grid-cols-1 md:grid-cols-3 gap-4"
                >
                    <div>
                        <label
                            for="search"
                            class="block text-sm font-medium text-gray-700 mb-1"
                            >Search</label
                        >
                        <input
                            type="text"
                            id="search"
                            name="search"
                            placeholder="Search by name, role, or company..."
                            class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-transparent"
                        />
                    </div>
                    <div>
                        <label
                            for="year"
                            class="block text-sm font-medium text-gray-700 mb-1"
                            >Graduation Year</label
                        >
                        <select
                            id="year"
                            name="year"
                            class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-transparent"
                        >
                            <option value="">All Years</option>
                            {
                                graduationYears.map((year) => (
                                    <option value={year}>{year}</option>
                                ))
                            }
                        </select>
                    </div>
                    <div>
                        <label
                            for="location"
                            class="block text-sm font-medium text-gray-700 mb-1"
                            >Location</label
                        >
                        <select
                            id="location"
                            name="location"
                            class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-transparent"
                        >
                            <option value="">All Locations</option>
                            {
                                locations.map((location) => (
                                    <option value={location}>{location}</option>
                                ))
                            }
                        </select>
                    </div>
                </form>
            </div>

            <!-- Alumni Grid -->
            <div
                id="alumni-grid"
                class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6"
            >
                {
                    sortedAlumni.map((alumni) => (
                        <a
                            href={`/alumni/${alumni.id}`}
                            class="alumni-card bg-gray-50 rounded-lg p-6 shadow-md hover:shadow-lg transition group"
                            data-name={alumni.data.name.toLowerCase()}
                            data-role={(
                                alumni.data.currentRole || ""
                            ).toLowerCase()}
                            data-company={(
                                alumni.data.company || ""
                            ).toLowerCase()}
                            data-year={alumni.data.graduationYear}
                            data-location={alumni.data.location || ""}
                        >
                            <div class="flex items-center space-x-4 mb-4">
                                <div class="bg-green-200 text-green-800 rounded-full w-16 h-16 flex items-center justify-center text-2xl font-bold group-hover:scale-110 transition">
                                    {alumni.data.name.charAt(0)}
                                </div>
                                <div>
                                    <h3 class="text-xl font-semibold group-hover:text-green-700 transition">
                                        {alumni.data.name}
                                    </h3>
                                    <p class="text-gray-600">
                                        Class of {alumni.data.graduationYear}
                                    </p>
                                </div>
                            </div>
                            {alumni.data.currentRole && (
                                <p class="text-gray-700 mb-1">
                                    {alumni.data.currentRole}
                                    {alumni.data.company && (
                                        <span class="text-gray-500">
                                            {" "}
                                            at {alumni.data.company}
                                        </span>
                                    )}
                                </p>
                            )}
                            {alumni.data.location && (
                                <p class="text-gray-500 text-sm flex items-center">
                                    <svg
                                        class="w-4 h-4 mr-1"
                                        fill="none"
                                        stroke="currentColor"
                                        viewBox="0 0 24 24"
                                    >
                                        <path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            stroke-width="2"
                                            d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
                                        />
                                        <path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            stroke-width="2"
                                            d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"
                                        />
                                    </svg>
                                    {alumni.data.location}
                                </p>
                            )}
                        </a>
                    ))
                }
            </div>

            <!-- No Results -->
            <div id="no-results" class="hidden text-center py-12">
                <p class="text-gray-500 text-lg">
                    No alumni found matching your criteria.
                </p>
            </div>
        </div>
    </section>
</Layout>

<script>
    const form = document.getElementById("filter-form");
    const searchInput = document.getElementById("search") as HTMLInputElement;
    const yearSelect = document.getElementById("year") as HTMLSelectElement;
    const locationSelect = document.getElementById(
        "location",
    ) as HTMLSelectElement;
    const cards = document.querySelectorAll(".alumni-card");
    const noResults = document.getElementById("no-results");

    function filterAlumni() {
        const search = searchInput.value.toLowerCase();
        const year = yearSelect.value;
        const location = locationSelect.value;

        let visibleCount = 0;

        cards.forEach((card) => {
            const cardEl = card as HTMLElement;
            const name = cardEl.dataset.name || "";
            const role = cardEl.dataset.role || "";
            const company = cardEl.dataset.company || "";
            const cardYear = cardEl.dataset.year || "";
            const cardLocation = cardEl.dataset.location || "";

            const matchesSearch =
                !search ||
                name.includes(search) ||
                role.includes(search) ||
                company.includes(search);
            const matchesYear = !year || cardYear === year;
            const matchesLocation =
                !location ||
                cardLocation.toLowerCase() === location.toLowerCase();

            if (matchesSearch && matchesYear && matchesLocation) {
                cardEl.style.display = "block";
                visibleCount++;
            } else {
                cardEl.style.display = "none";
            }
        });

        if (noResults) {
            noResults.classList.toggle("hidden", visibleCount > 0);
        }
    }

    form.addEventListener("input", filterAlumni);
    form.addEventListener("change", filterAlumni);
</script>
