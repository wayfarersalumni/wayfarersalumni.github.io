---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
    const alumni = await getCollection("alumni");
    return alumni.map((person) => ({
        params: { slug: person.id },
        props: { alumni: person },
    }));
}

const { alumni } = Astro.props;
---

<Layout
    title={alumni.data.name}
    description={alumni.data.bio ||
        `Profile of ${alumni.data.name}, Wayfarers Alumni`}
>
    <section class="py-16 bg-white">
        <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
            <a
                href="/alumni"
                class="inline-flex items-center text-green-700 hover:text-green-800 mb-8"
            >
                <svg
                    class="w-4 h-4 mr-2"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M15 19l-7-7 7-7"></path>
                </svg>
                Back to Alumni Directory
            </a>

            <div class="bg-gray-50 rounded-lg p-8 shadow-md">
                <div
                    class="flex flex-col md:flex-row items-start md:items-center gap-8 mb-8"
                >
                    <div
                        class="bg-green-200 text-green-800 rounded-full w-32 h-32 flex items-center justify-center text-4xl font-bold"
                    >
                        {alumni.data.name.charAt(0)}
                    </div>
                    <div class="flex-1">
                        <h1 class="text-4xl font-bold mb-2">
                            {alumni.data.name}
                        </h1>
                        <p class="text-xl text-gray-600">
                            Class of {alumni.data.graduationYear}
                        </p>
                        {
                            alumni.data.location && (
                                <p class="text-gray-500 flex items-center mt-2">
                                    <svg
                                        class="w-5 h-5 mr-2"
                                        fill="none"
                                        stroke="currentColor"
                                        viewBox="0 0 24 24"
                                    >
                                        <path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            stroke-width="2"
                                            d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
                                        />
                                        <path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            stroke-width="2"
                                            d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"
                                        />
                                    </svg>
                                    {alumni.data.location}
                                </p>
                            )
                        }
                    </div>
                </div>

                {
                    alumni.data.bio && (
                        <div class="mb-8">
                            <h2 class="text-2xl font-semibold mb-4">About</h2>
                            <p class="text-gray-700 leading-relaxed">
                                {alumni.data.bio}
                            </p>
                        </div>
                    )
                }

                {
                    (alumni.data.currentRole || alumni.data.company) && (
                        <div class="mb-8">
                            <h2 class="text-2xl font-semibold mb-4">
                                Current Role
                            </h2>
                            <p class="text-gray-700">
                                {alumni.data.currentRole}
                                {alumni.data.company && (
                                    <span class="text-gray-500">
                                        {" "}
                                        at {alumni.data.company}
                                    </span>
                                )}
                            </p>
                        </div>
                    )
                }

                {
                    (alumni.data.linkedin ||
                        alumni.data.twitter ||
                        alumni.data.instagram) && (
                        <div class="mb-8">
                            <h2 class="text-2xl font-semibold mb-4">Connect</h2>
                            <div class="flex flex-wrap gap-4">
                                {alumni.data.linkedin && (
                                    <a
                                        href={alumni.data.linkedin}
                                        target="_blank"
                                        rel="noopener noreferrer"
                                        class="inline-flex items-center px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition"
                                    >
                                        <svg
                                            class="w-5 h-5 mr-2"
                                            fill="currentColor"
                                            viewBox="0 0 24 24"
                                        >
                                            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
                                        </svg>
                                        LinkedIn
                                    </a>
                                )}
                                {alumni.data.twitter && (
                                    <a
                                        href={alumni.data.twitter}
                                        target="_blank"
                                        rel="noopener noreferrer"
                                        class="inline-flex items-center px-4 py-2 bg-sky-500 text-white rounded-lg hover:bg-sky-600 transition"
                                    >
                                        <svg
                                            class="w-5 h-5 mr-2"
                                            fill="currentColor"
                                            viewBox="0 0 24 24"
                                        >
                                            <path d="M23.953 4.57a10 10 0 01-2.825.775 4.958 4.958 0 002.163-2.723c-.951.555-2.005.959-3.127 1.184a4.92 4.92 0 00-8.384 4.482C7.69 8.095 4.067 6.13 1.64 3.162a4.822 4.822 0 00-.666 2.475c0 1.71.87 3.213 2.188 4.096a4.904 4.904 0 01-2.228-.616v.06a4.923 4.923 0 003.946 4.827 4.996 4.996 0 01-2.212.085 4.936 4.936 0 004.604 3.417 9.867 9.867 0 01-6.102 2.105c-.39 0-.779-.023-1.17-.067a13.995 13.995 0 007.557 2.209c9.053 0 13.998-7.496 13.998-13.985 0-.21 0-.42-.015-.63A9.935 9.935 0 0024 4.59z" />
                                        </svg>
                                        Twitter
                                    </a>
                                )}
                                {alumni.data.instagram && (
                                    <a
                                        href={alumni.data.instagram}
                                        target="_blank"
                                        rel="noopener noreferrer"
                                        class="inline-flex items-center px-4 py-2 bg-pink-600 text-white rounded-lg hover:bg-pink-700 transition"
                                    >
                                        <svg
                                            class="w-5 h-5 mr-2"
                                            fill="currentColor"
                                            viewBox="0 0 24 24"
                                        >
                                            <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z" />
                                        </svg>
                                        Instagram
                                    </a>
                                )}
                            </div>
                        </div>
                    )
                }

                {
                    alumni.data.email && (
                        <div>
                            <a
                                href={`mailto:${alumni.data.email}`}
                                class="inline-flex items-center px-6 py-3 bg-green-700 text-white rounded-lg hover:bg-green-800 transition"
                            >
                                <svg
                                    class="w-5 h-5 mr-2"
                                    fill="none"
                                    stroke="currentColor"
                                    viewBox="0 0 24 24"
                                >
                                    <path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                                    />
                                </svg>
                                Contact {alumni.data.name.split(" ")[0]}
                            </a>
                        </div>
                    )
                }
            </div>
        </div>
    </section>
</Layout>
