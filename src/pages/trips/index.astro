---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";

const allTrips = await getCollection("trips");
const sortedTrips = allTrips.sort(
    (a, b) => b.data.tripDate.valueOf() - a.data.tripDate.valueOf(),
);
---

<Layout
    title="Trip Reports"
    description="Trip reports and photo galleries from Wayfarers Alumni adventures"
>
    <section class="py-16 bg-white">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <h1 class="text-4xl font-bold text-center mb-4">Trip Reports</h1>
            <p class="text-xl text-gray-600 text-center mb-12">
                Adventures shared by Wayfarers Alumni
            </p>

            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                {
                    sortedTrips.map((trip) => (
                        <article class="bg-gray-50 rounded-lg shadow-md overflow-hidden hover:shadow-lg transition">
                            {trip.data.photos &&
                                trip.data.photos.length > 0 && (
                                    <img
                                        src={trip.data.photos[0]}
                                        alt={trip.data.title}
                                        class="w-full h-48 object-cover"
                                    />
                                )}
                            <div class="p-6">
                                <time
                                    class="text-sm text-gray-500"
                                    datetime={trip.data.tripDate.toISOString()}
                                >
                                    {trip.data.tripDate.toLocaleDateString(
                                        "en-GB",
                                        {
                                            year: "numeric",
                                            month: "long",
                                            day: "numeric",
                                        },
                                    )}
                                </time>
                                <h2 class="text-xl font-semibold mt-2 mb-2">
                                    {trip.data.title}
                                </h2>
                                <p class="text-gray-600 mb-4">
                                    {trip.data.description}
                                </p>

                                <div class="flex flex-wrap gap-2 mb-4 text-sm">
                                    <span class="px-2 py-1 bg-green-100 text-green-800 rounded-full">
                                        {trip.data.location}
                                    </span>
                                    {trip.data.difficulty && (
                                        <span
                                            class={`px-2 py-1 rounded-full ${
                                                trip.data.difficulty === "Easy"
                                                    ? "bg-green-100 text-green-800"
                                                    : trip.data.difficulty ===
                                                        "Moderate"
                                                      ? "bg-yellow-100 text-yellow-800"
                                                      : trip.data.difficulty ===
                                                          "Challenging"
                                                        ? "bg-orange-100 text-orange-800"
                                                        : "bg-red-100 text-red-800"
                                            }`}
                                        >
                                            {trip.data.difficulty}
                                        </span>
                                    )}
                                </div>

                                <div class="flex flex-wrap gap-4 text-sm text-gray-500 mb-4">
                                    {trip.data.distance && (
                                        <span>📏 {trip.data.distance}</span>
                                    )}
                                    {trip.data.elevation && (
                                        <span>⛰ {trip.data.elevation}</span>
                                    )}
                                    {trip.data.route && (
                                        <span>🗺 {trip.data.route}</span>
                                    )}
                                </div>

                                <a
                                    href={`/trips/${trip.id}`}
                                    class="inline-flex items-center text-green-700 hover:text-green-800 font-medium"
                                >
                                    View Trip Report
                                    <svg
                                        class="w-4 h-4 ml-1"
                                        fill="none"
                                        stroke="currentColor"
                                        viewBox="0 0 24 24"
                                    >
                                        <path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            stroke-width="2"
                                            d="M9 5l7 7-7 7"
                                        />
                                    </svg>
                                </a>
                            </div>
                        </article>
                    ))
                }
            </div>

            {
                sortedTrips.length === 0 && (
                    <div class="text-center py-12">
                        <p class="text-gray-500 text-lg">
                            No trip reports yet. Share your adventures with us!
                        </p>
                    </div>
                )
            }
        </div>
    </section>
</Layout>
