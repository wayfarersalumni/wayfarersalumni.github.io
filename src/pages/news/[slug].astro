---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
    const news = await getCollection("news");
    return news.map((post) => ({
        params: { slug: post.id },
        props: { news: post },
    }));
}

const { news } = Astro.props;
---

<Layout title={news.data.title} description={news.data.description}>
    <article class="py-16 bg-white">
        <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
            <a
                href="/news"
                class="inline-flex items-center text-green-700 hover:text-green-800 mb-8"
            >
                <svg
                    class="w-4 h-4 mr-2"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M15 19l-7-7 7-7"></path>
                </svg>
                Back to News
            </a>

            {
                news.data.image && (
                    <img
                        src={news.data.image}
                        alt={news.data.title}
                        class="w-full h-64 md:h-96 object-cover rounded-lg shadow-lg mb-8"
                    />
                )
            }

            <header class="mb-8">
                <time
                    class="text-sm text-gray-500"
                    datetime={news.data.pubDate.toISOString()}
                >
                    {
                        news.data.pubDate.toLocaleDateString("en-GB", {
                            year: "numeric",
                            month: "long",
                            day: "numeric",
                        })
                    }
                </time>
                <h1 class="text-4xl font-bold mt-2 mb-4">{news.data.title}</h1>
                {
                    news.data.author && (
                        <p class="text-gray-600">By {news.data.author}</p>
                    )
                }
                {
                    news.data.tags && news.data.tags.length > 0 && (
                        <div class="flex flex-wrap gap-2 mt-4">
                            {news.data.tags.map((tag) => (
                                <span class="px-2 py-1 bg-green-100 text-green-800 text-xs rounded-full">
                                    {tag}
                                </span>
                            ))}
                        </div>
                    )
                }
            </header>

            <div class="prose prose-lg max-w-none">
                <slot />
            </div>

            <footer class="mt-12 pt-8 border-t">
                <div class="flex items-center justify-between">
                    <a
                        href="/news"
                        class="inline-flex items-center text-green-700 hover:text-green-800 font-medium"
                    >
                        <svg
                            class="w-4 h-4 mr-2"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M15 19l-7-7 7-7"></path>
                        </svg>
                        Back to News
                    </a>
                    <a
                        href="mailto:wayfarersalumni@gmail.com"
                        class="inline-flex items-center text-green-700 hover:text-green-800"
                    >
                        <svg
                            class="w-5 h-5 mr-2"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                            ></path>
                        </svg>
                        Contact Us
                    </a>
                </div>
            </footer>
        </div>
    </article>
</Layout>
