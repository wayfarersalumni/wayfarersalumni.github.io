---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";

const allNews = await getCollection("news");
const sortedNews = allNews
    .filter((news) => !news.data.draft)
    .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<Layout
    title="News & Updates"
    description="Latest news and updates from Wayfarers Alumni"
>
    <section class="py-16 bg-white">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <h1 class="text-4xl font-bold text-center mb-4">News & Updates</h1>
            <p class="text-xl text-gray-600 text-center mb-12">
                Stay up to date with the latest from Wayfarers Alumni
            </p>

            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                {
                    sortedNews.map((news) => (
                        <article class="bg-gray-50 rounded-lg shadow-md overflow-hidden hover:shadow-lg transition flex flex-col">
                            {news.data.image && (
                                <img
                                    src={news.data.image}
                                    alt={news.data.title}
                                    class="w-full h-48 object-cover"
                                />
                            )}
                            <div class="p-6 flex-1 flex flex-col">
                                <time
                                    class="text-sm text-gray-500"
                                    datetime={news.data.pubDate.toISOString()}
                                >
                                    {news.data.pubDate.toLocaleDateString(
                                        "en-GB",
                                        {
                                            year: "numeric",
                                            month: "long",
                                            day: "numeric",
                                        },
                                    )}
                                </time>
                                <h2 class="text-xl font-semibold mt-2 mb-3">
                                    {news.data.title}
                                </h2>
                                <p class="text-gray-600 mb-4 flex-1">
                                    {news.data.description}
                                </p>
                                {news.data.tags &&
                                    news.data.tags.length > 0 && (
                                        <div class="flex flex-wrap gap-2 mb-4">
                                            {news.data.tags.map((tag) => (
                                                <span class="px-2 py-1 bg-green-100 text-green-800 text-xs rounded-full">
                                                    {tag}
                                                </span>
                                            ))}
                                        </div>
                                    )}
                                <a
                                    href={`/news/${news.id}`}
                                    class="inline-flex items-center text-green-700 hover:text-green-800 font-medium"
                                >
                                    Read More
                                    <svg
                                        class="w-4 h-4 ml-1"
                                        fill="none"
                                        stroke="currentColor"
                                        viewBox="0 0 24 24"
                                    >
                                        <path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            stroke-width="2"
                                            d="M9 5l7 7-7 7"
                                        />
                                    </svg>
                                </a>
                            </div>
                        </article>
                    ))
                }
            </div>

            {
                sortedNews.length === 0 && (
                    <div class="text-center py-12">
                        <p class="text-gray-500 text-lg">
                            No news articles yet. Check back soon!
                        </p>
                    </div>
                )
            }
        </div>
    </section>
</Layout>
