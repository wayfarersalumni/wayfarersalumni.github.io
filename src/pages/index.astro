---
import Layout from "../layouts/Layout.astro";
import { getCollection } from "astro:content";

// Get featured alumni
const featuredAlumni = (await getCollection("alumni"))
	.filter((alumni) => alumni.data.featured)
	.slice(0, 6);

// Get latest news
const latestNews = (await getCollection("news"))
	.filter((news) => !news.data.draft)
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 3);

// Get upcoming events
const upcomingEvents = (await getCollection("events"))
	.filter((event) => event.data.eventDate >= new Date())
	.sort((a, b) => a.data.eventDate.valueOf() - b.data.eventDate.valueOf())
	.slice(0, 3);
---

<Layout
	title="Wayfarers Alumni - Home"
	description="Connecting Wayfarers Hiking Society alumni worldwide"
>
	<!-- Hero Section -->
	<section
		class="bg-gradient-to-br from-green-800 to-green-900 text-white py-20"
	>
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
			<h1 class="text-4xl md:text-6xl font-bold mb-6">
				Wayfarers Alumni
			</h1>
			<p
				class="text-xl md:text-2xl text-green-100 mb-8 max-w-3xl mx-auto"
			>
				Connecting Wayfarers Hiking Society alumni worldwide. Preserving
				memories, fostering friendships, and continuing the adventure.
			</p>
			<div class="flex flex-wrap justify-center gap-4">
				<a
					href="/alumni"
					class="bg-white text-green-800 px-6 py-3 rounded-lg font-semibold hover:bg-green-100 transition"
				>
					View Alumni Directory
				</a>
				<a
					href="/contact"
					class="border-2 border-white px-6 py-3 rounded-lg font-semibold hover:bg-white hover:text-green-800 transition"
				>
					Get in Touch
				</a>
			</div>
		</div>
	</section>

	<!-- Featured Alumni -->
	{
		featuredAlumni.length > 0 && (
			<section class="py-16 bg-white">
				<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
					<h2 class="text-3xl font-bold text-center mb-12">
						Featured Alumni
					</h2>
					<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
						{featuredAlumni.map((alumni) => (
							<div class="bg-gray-50 rounded-lg p-6 shadow-md hover:shadow-lg transition">
								<div class="flex items-center space-x-4 mb-4">
									<div class="bg-green-200 text-green-800 rounded-full w-16 h-16 flex items-center justify-center text-2xl font-bold">
										{alumni.data.name.charAt(0)}
									</div>
									<div>
										<h3 class="text-xl font-semibold">
											{alumni.data.name}
										</h3>
										<p class="text-gray-600">
											Class of{" "}
											{alumni.data.graduationYear}
										</p>
									</div>
								</div>
								{alumni.data.currentRole && (
									<p class="text-gray-700 mb-2">
										{alumni.data.currentRole}
										{alumni.data.company &&
											` at ${alumni.data.company}`}
									</p>
								)}
								{alumni.data.location && (
									<p class="text-gray-500 text-sm">
										{alumni.data.location}
									</p>
								)}
								<a
									href={`/alumni/${alumni.id}`}
									class="inline-block mt-4 text-green-700 hover:text-green-800 font-medium"
								>
									View Profile →
								</a>
							</div>
						))}
					</div>
					<div class="text-center mt-8">
						<a
							href="/alumni"
							class="text-green-700 hover:text-green-800 font-medium"
						>
							View All Alumni →
						</a>
					</div>
				</div>
			</section>
		)
	}

	<!-- Latest News -->
	{
		latestNews.length > 0 && (
			<section class="py-16 bg-gray-50">
				<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
					<h2 class="text-3xl font-bold text-center mb-12">
						Latest News
					</h2>
					<div class="grid grid-cols-1 md:grid-cols-3 gap-8">
						{latestNews.map((news) => (
							<article class="bg-white rounded-lg shadow-md overflow-hidden hover:shadow-lg transition">
								{news.data.image && (
									<img
										src={news.data.image}
										alt={news.data.title}
										class="w-full h-48 object-cover"
									/>
								)}
								<div class="p-6">
									<time
										class="text-sm text-gray-500"
										datetime={news.data.pubDate.toISOString()}
									>
										{news.data.pubDate.toLocaleDateString(
											"en-GB",
											{
												year: "numeric",
												month: "long",
												day: "numeric",
											},
										)}
									</time>
									<h3 class="text-xl font-semibold mt-2 mb-3">
										{news.data.title}
									</h3>
									<p class="text-gray-600 mb-4">
										{news.data.description}
									</p>
									<a
										href={`/news/${news.id}`}
										class="text-green-700 hover:text-green-800 font-medium"
									>
										Read More →
									</a>
								</div>
							</article>
						))}
					</div>
					<div class="text-center mt-8">
						<a
							href="/news"
							class="text-green-700 hover:text-green-800 font-medium"
						>
							View All News →
						</a>
					</div>
				</div>
			</section>
		)
	}

	<!-- Upcoming Events -->
	{
		upcomingEvents.length > 0 && (
			<section class="py-16 bg-white">
				<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
					<h2 class="text-3xl font-bold text-center mb-12">
						Upcoming Events
					</h2>
					<div class="grid grid-cols-1 md:grid-cols-3 gap-8">
						{upcomingEvents.map((event) => (
							<div class="bg-gray-50 rounded-lg p-6 shadow-md hover:shadow-lg transition">
								<div class="text-center mb-4">
									<span class="text-4xl font-bold text-green-700">
										{event.data.eventDate.toLocaleDateString(
											"en-GB",
											{ day: "numeric" },
										)}
									</span>
									<span class="text-xl text-green-600 block">
										{event.data.eventDate.toLocaleDateString(
											"en-GB",
											{ month: "long", year: "numeric" },
										)}
									</span>
								</div>
								<h3 class="text-xl font-semibold text-center mb-2">
									{event.data.title}
								</h3>
								<p class="text-gray-600 text-center mb-4">
									{event.data.location}
								</p>
								<p class="text-gray-500 text-sm mb-4">
									{event.data.description}
								</p>
								{event.data.registrationUrl ? (
									<a
										href={event.data.registrationUrl}
										target="_blank"
										rel="noopener noreferrer"
										class="block text-center bg-green-700 text-white py-2 rounded-lg hover:bg-green-800 transition"
									>
										Register Now
									</a>
								) : (
									<a
										href="/events"
										class="block text-center text-green-700 hover:text-green-800 font-medium"
									>
										Learn More →
									</a>
								)}
							</div>
						))}
					</div>
					<div class="text-center mt-8">
						<a
							href="/events"
							class="text-green-700 hover:text-green-800 font-medium"
						>
							View All Events →
						</a>
					</div>
				</div>
			</section>
		)
	}

	<!-- About Preview -->
	<section class="py-16 bg-green-800 text-white">
		<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
			<h2 class="text-3xl font-bold mb-6">About Wayfarers Alumni</h2>
			<p class="text-xl text-green-100 mb-8">
				We are the alumni group of the Wayfarers Hiking Society, part of
				the University of Birmingham Guild of Students. While we operate
				independently from the society, the university, and the guild,
				we maintain the spirit of adventure and camaraderie that defined
				our time hiking together.
			</p>
			<a
				href="/about"
				class="inline-block bg-white text-green-800 px-6 py-3 rounded-lg font-semibold hover:bg-green-100 transition"
			>
				Learn More About Us
			</a>
		</div>
	</section>

	<!-- Donate CTA -->
	<section class="py-16 bg-gray-50">
		<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
			<h2 class="text-3xl font-bold mb-6">Support Our Community</h2>
			<p class="text-xl text-gray-600 mb-8">
				Your donations help us organize events, maintain our website,
				and keep the Wayfarers spirit alive for future generations of
				alumni.
			</p>
			<a
				href="/donate"
				class="inline-block bg-green-700 text-white px-8 py-4 rounded-lg font-semibold hover:bg-green-800 transition text-lg"
			>
				Make a Donation
			</a>
		</div>
	</section>
</Layout>
