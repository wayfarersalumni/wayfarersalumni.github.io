---
import Layout from "../layouts/Layout.astro";
---

<Layout
    title="Support Us"
    description="Support Wayfarers Alumni with a donation"
>
    <section class="py-16 bg-white">
        <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
            <h1 class="text-4xl font-bold text-center mb-8">
                Support Our Community
            </h1>

            <div class="prose prose-lg max-w-none">
                <p class="text-xl text-gray-600 text-center mb-12">
                    Your generous donations help us organize events, maintain
                    our website, and keep the Wayfarers spirit alive for future
                    generations of alumni.
                </p>

                <div class="bg-green-50 p-8 rounded-lg mb-12">
                    <h2 class="text-2xl font-bold mb-6 text-center">
                        How Your Donation Helps
                    </h2>
                    <div class="grid md:grid-cols-3 gap-6">
                        <div class="text-center">
                            <div class="text-4xl mb-4">🎉</div>
                            <h3 class="font-semibold mb-2">
                                Event Organization
                            </h3>
                            <p class="text-gray-600 text-sm">
                                Help us host reunions, socials, and group hikes
                                for alumni to reconnect.
                            </p>
                        </div>
                        <div class="text-center">
                            <div class="text-4xl mb-4">🌐</div>
                            <h3 class="font-semibold mb-2">
                                Website & Technology
                            </h3>
                            <p class="text-gray-600 text-sm">
                                Maintain and improve our online presence to keep
                                the community connected.
                            </p>
                        </div>
                        <div class="text-center">
                            <div class="text-4xl mb-4">📸</div>
                            <h3 class="font-semibold mb-2">Photo Archives</h3>
                            <p class="text-gray-600 text-sm">
                                Preserve and share historical photos and
                                memories from Wayfarers history.
                            </p>
                        </div>
                    </div>
                </div>

                <h2 class="text-2xl font-bold mb-6">Make a Donation</h2>
                <p class="mb-6">
                    We accept donations via bank transfer or payment platforms.
                    Please contact us at
                    <a
                        href="mailto:wayfarersalumni@gmail.com"
                        class="text-green-700 hover:text-green-800"
                        >wayfarersalumni@gmail.com</a
                    >
                    for donation details and arrangements.
                </p>

                <div class="bg-gray-50 p-6 rounded-lg mb-8">
                    <h3 class="text-xl font-semibold mb-4">
                        Bank Transfer Details
                    </h3>
                    <dl class="grid grid-cols-2 gap-4 text-sm">
                        <dt class="font-medium text-gray-600">Account Name:</dt>
                        <dd class="text-gray-900">
                            Wayfarers Alumni Association
                        </dd>
                        <dt class="font-medium text-gray-600">Sort Code:</dt>
                        <dd class="text-gray-900">XX-XX-XX</dd>
                        <dt class="font-medium text-gray-600">
                            Account Number:
                        </dt>
                        <dd class="text-gray-900">XXXXXXXX</dd>
                        <dt class="font-medium text-gray-600">Reference:</dt>
                        <dd class="text-gray-900">Your Name + "Donation"</dd>
                    </dl>
                </div>

                <div class="bg-yellow-50 border-l-4 border-yellow-400 p-4 mb-8">
                    <p class="text-yellow-800 text-sm">
                        <strong>Note:</strong> Wayfarers Alumni is an independent
                        organization. Donations are not tax-deductible unless otherwise
                        stated. Please contact us if you need any clarification.
                    </p>
                </div>

                <div class="text-center">
                    <p class="text-gray-600 mb-4">
                        Questions about donating? We're happy to help!
                    </p>
                    <a
                        href="mailto:wayfarersalumni@gmail.com"
                        class="inline-flex items-center text-green-700 hover:text-green-800 font-medium"
                    >
                        <svg
                            class="w-5 h-5 mr-2"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                            ></path>
                        </svg>
                        Contact Us
                    </a>
                </div>
            </div>
        </div>
    </section>
</Layout>
