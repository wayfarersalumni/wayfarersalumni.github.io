---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";

const allEvents = await getCollection("events");
const upcomingEvents = allEvents
    .filter((event) => event.data.eventDate >= new Date())
    .sort((a, b) => a.data.eventDate.valueOf() - b.data.eventDate.valueOf());

const pastEvents = allEvents
    .filter((event) => event.data.eventDate < new Date())
    .sort((a, b) => b.data.eventDate.valueOf() - a.data.eventDate.valueOf());
---

<Layout
    title="Events"
    description="Upcoming events and reunions for Wayfarers Alumni"
>
    <section class="py-16 bg-white">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <h1 class="text-4xl font-bold text-center mb-4">Events</h1>
            <p class="text-xl text-gray-600 text-center mb-12">
                Join us at reunions, meetups, and social gatherings
            </p>

            <!-- Upcoming Events -->
            {
                upcomingEvents.length > 0 && (
                    <div class="mb-16">
                        <h2 class="text-2xl font-bold mb-8 flex items-center">
                            <svg
                                class="w-6 h-6 mr-2 text-green-600"
                                fill="none"
                                stroke="currentColor"
                                viewBox="0 0 24 24"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"
                                />
                            </svg>
                            Upcoming Events
                        </h2>
                        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                            {upcomingEvents.map((event) => (
                                <div class="bg-gray-50 rounded-lg shadow-md overflow-hidden hover:shadow-lg transition">
                                    <div class="bg-green-700 text-white p-4 text-center">
                                        <span class="text-4xl font-bold block">
                                            {event.data.eventDate.toLocaleDateString(
                                                "en-GB",
                                                { day: "numeric" },
                                            )}
                                        </span>
                                        <span class="text-lg">
                                            {event.data.eventDate.toLocaleDateString(
                                                "en-GB",
                                                {
                                                    month: "long",
                                                    year: "numeric",
                                                },
                                            )}
                                        </span>
                                    </div>
                                    <div class="p-6">
                                        <h3 class="text-xl font-semibold mb-2">
                                            {event.data.title}
                                        </h3>
                                        <p class="text-gray-600 mb-4">
                                            {event.data.description}
                                        </p>
                                        <div class="flex items-center text-gray-500 text-sm mb-4">
                                            <svg
                                                class="w-4 h-4 mr-2"
                                                fill="none"
                                                stroke="currentColor"
                                                viewBox="0 0 24 24"
                                            >
                                                <path
                                                    stroke-linecap="round"
                                                    stroke-linejoin="round"
                                                    stroke-width="2"
                                                    d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
                                                />
                                                <path
                                                    stroke-linecap="round"
                                                    stroke-linejoin="round"
                                                    stroke-width="2"
                                                    d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"
                                                />
                                            </svg>
                                            {event.data.location}
                                        </div>
                                        {event.data.registrationUrl ? (
                                            <a
                                                href={
                                                    event.data.registrationUrl
                                                }
                                                target="_blank"
                                                rel="noopener noreferrer"
                                                class="block w-full text-center bg-green-700 text-white py-2 rounded-lg hover:bg-green-800 transition"
                                            >
                                                Register Now (Google Form)
                                            </a>
                                        ) : (
                                            <a
                                                href="/contact"
                                                class="block w-full text-center border border-green-700 text-green-700 py-2 rounded-lg hover:bg-green-50 transition"
                                            >
                                                Contact for Details
                                            </a>
                                        )}
                                    </div>
                                </div>
                            ))}
                        </div>
                    </div>
                )
            }

            <!-- Past Events -->
            {
                pastEvents.length > 0 && (
                    <div>
                        <h2 class="text-2xl font-bold mb-8 flex items-center">
                            <svg
                                class="w-6 h-6 mr-2 text-gray-600"
                                fill="none"
                                stroke="currentColor"
                                viewBox="0 0 24 24"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"
                                />
                            </svg>
                            Past Events
                        </h2>
                        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                            {pastEvents.map((event) => (
                                <div class="bg-gray-100 rounded-lg p-6 opacity-75">
                                    <div class="text-center mb-4">
                                        <span class="text-3xl font-bold text-gray-700">
                                            {event.data.eventDate.toLocaleDateString(
                                                "en-GB",
                                                { day: "numeric" },
                                            )}
                                        </span>
                                        <span class="text-lg text-gray-600 block">
                                            {event.data.eventDate.toLocaleDateString(
                                                "en-GB",
                                                {
                                                    month: "long",
                                                    year: "numeric",
                                                },
                                            )}
                                        </span>
                                    </div>
                                    <h3 class="text-lg font-semibold text-center mb-2 text-gray-800">
                                        {event.data.title}
                                    </h3>
                                    <p class="text-gray-600 text-center text-sm">
                                        {event.data.location}
                                    </p>
                                </div>
                            ))}
                        </div>
                    </div>
                )
            }

            {
                allEvents.length === 0 && (
                    <div class="text-center py-12">
                        <p class="text-gray-500 text-lg mb-4">
                            No events scheduled yet.
                        </p>
                        <p class="text-gray-600">
                            Want to organize an event?{" "}
                            <a
                                href="/contact"
                                class="text-green-700 hover:text-green-800 font-medium"
                            >
                                Get in touch!
                            </a>
                        </p>
                    </div>
                )
            }
        </div>
    </section>
</Layout>
